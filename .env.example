# Project paths (optional; defaults to repo root / data)
TAWASOL_PROJECT_ROOT=
TAWASOL_DATA_DIR=data
TAWASOL_PROCESSED_DIR=data/processed

# Pinecone (optional — if unset, a local embedding index is used)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=tawasol-risk-nist
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Optional LLM for narrative polish (OpenAI-compatible: Groq, OpenRouter, etc.)
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

# Embeddings (local sentence-transformers by default)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
