# ── Application ─────────────────────────────────────────────────────────────
CYBER_RISK_PROJECT_ROOT=
CYBER_RISK_DATA_DIR=data
CYBER_RISK_PROCESSED_DIR=data/processed
ORGANIZATION_NAME=Your Company
LOG_LEVEL=INFO

# Run KEV + NIST file cache download on startup if missing (first boot can take 1–2 min)
CYBER_RISK_AUTO_BOOTSTRAP=true

# ── Groq (optional — polishes final Markdown wording only) ───────────────────
LLM_PROVIDER=none
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Vector store (production: use Pinecone on Railway) ───────────────────────
# Local dev: leave PINECONE_API_KEY empty → uses data/processed/*.npz
PINECONE_API_KEY=
PINECONE_INDEX_NAME=cyber-risk-nist
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Ignore expired HuggingFace tokens on disk (fixes 401 on public models)
HF_HUB_DISABLE_IMPLICIT_TOKEN=1
# Force offline hashing embedder if HF download still fails: EMBEDDING_BACKEND=hashing
